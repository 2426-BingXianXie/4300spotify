# Submission ignores — keep this file conservative.
# The repo is pushed to GitHub and the GitHub URL IS the submission, so
# nothing here should ever ship that isn't strictly required for grading.

# -------- Python --------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
.python-version

# -------- Virtual environments --------
.venv/
venv/
env/
ENV/

# -------- Secrets / local env --------
.env
.env.local
.env.*.local
.envrc

# -------- OS / editor noise --------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.tmp
*.temp

# -------- Agent / IDE state (never part of submission) --------
.cursor/
.claude/
.codex/

# -------- Pipeline artifacts (regenerated by src/preprocess.py + src/similarity.py) --------
data/sample.csv
data/similarity.csv
data/*.tmp
data/*.parquet
data/*.feather

# -------- Logs --------
*.log
logs/

# -------- Archives (we push to GitHub; never commit zips/tarballs) --------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# -------- Intermediate poster build artifacts (poster.pdf itself IS tracked) --------
# These globs intentionally do NOT match `poster.pdf`.
poster*.png
poster*.svg
poster*.jpg
poster*.jpeg
poster*.gif
poster_draft*.pdf
poster_*.tmp.pdf

# -------- Jupyter --------
.ipynb_checkpoints/
*.ipynb

# -------- Build / dist --------
build/
dist/
*.egg

# -------- Misc --------
*.sqlite
*.sqlite3
*.db
node_modules/

# -------- Markdown docs (agent/scaffold files, not part of the submission) --------
# Agent-facing docs (AGENTS.md, plan.md, cursor.md, codex.md) are NOT pushed.
# README.md IS pushed — it documents the project for human readers/graders.
*.md
!README.md
